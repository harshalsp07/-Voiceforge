# VoiceForge - Environment Variables

# Appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your-database-id

# Appwrite Collection IDs
NEXT_PUBLIC_APPWRITE_BOOKS_COLLECTION=books
NEXT_PUBLIC_APPWRITE_VOICES_COLLECTION=voices
NEXT_PUBLIC_APPWRITE_AUDIOBOOKS_COLLECTION=audiobooks
NEXT_PUBLIC_APPWRITE_CHAPTERS_COLLECTION=chapters
NEXT_PUBLIC_APPWRITE_VIDEOS_COLLECTION=videos
NEXT_PUBLIC_APPWRITE_LLM_COLLECTION=llm_providers

# Appwrite Storage Bucket IDs
NEXT_PUBLIC_APPWRITE_BOOKS_BUCKET=books
NEXT_PUBLIC_APPWRITE_VOICES_BUCKET=voices
NEXT_PUBLIC_APPWRITE_AUDIO_BUCKET=audio
NEXT_PUBLIC_APPWRITE_VIDEOS_BUCKET=videos

# Kaggle Engine URL (from ngrok after starting notebook)
KAGGLE_ENGINE_URL=https://your-ngrok-url.ngrok.io

# Hugging Face (for model download in Kaggle)
HF_TOKEN=hf_your_token_here
